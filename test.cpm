#include <stdio.h>

class Point {
    int x;
    int y;
    pub void init(int x, int y) {
        self.x = x;
        self.y = y;
    }
    pub int sum() {return this->x+this->y;}
};

int main() {
    Point p[2];
    p[0].init(10,10);
    p[1].init(20,20);
    printf("%d\n", p[0].sum());
    printf("%d\n", p[1].sum());
    return 0;
}
