#include <stdio.h>

// support for self. as equivalent to this->
class Point {
    int x;
    int y;
    pub int init(int x, int y) {
        self.x = 10;
        self.y = 10;
    }
    pub int sum() {return this->x+this->y;}
};


int main() {
    Point p = .init(10,10);
    printf("%d\n", p.sum());
    return 0;
}
